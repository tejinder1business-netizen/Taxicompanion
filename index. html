        </div>
    </div> 

    <div id="caution-dir-pop" class="driver-modal caution-grid">
        <span class="modal-title">Caution Direction</span>
        <div class="grid-options">
            <button class="btn-caution-opt" onclick="dropCautionMarker('Northbound')">North</button>
            <button class="btn-caution-opt" onclick="dropCautionMarker('Southbound')">South</button>
            <button class="btn-caution-opt" onclick="dropCautionMarker('Eastbound')">East</button>
            <button class="btn-caution-opt" onclick="dropCautionMarker('Westbound')">West</button>
