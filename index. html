    </div> 

    <div class="side-util left-side">
        <button id="mute-toggle-btn" class="util-circle" onclick="handleMuteToggle()">AUDIO<br>ON</button>
        <button id="audio-repeat-btn" class="util-circle active-repeat" onclick="replayLastAudioNarration()">REPLAY<br>MSG</button>
    </div>
    <div class="side-util right-side">
        <button id="lock-center-btn" class="util-circle active-center" onclick="handleRecenter()">MAP<br>LOCKED</button>
    </div> 

    <div id="screen-overlay" class="modal-overlay" onclick="hideModals()"></div> 

    <div id="camera-menu-pop" class="driver-modal cam-list-grid">
        <span class="modal-title">Street View Cameras</span>
        <div class="grid-options" id="camera-list-options">
            <button class="btn-camera-select full-width-btn" onclick="toggleLiveCameraFeed('https://trafficcams.vancouver.ca/BurrardCornwall4.htm')">Burrard and Cornwall</button>
            <button class="btn-camera-select full-width-btn" onclick="toggleLiveCameraFeed('https://trafficcams.vancouver.ca/cambiebridge.htm')">Cambie Bridge</button>
            <button class="btn-camera-select full-width-btn" onclick="toggleLiveCameraFeed('https://trafficcams.vancouver.ca/granvilleHoweOnRamp.htm')">Granville Bridge</button>
            <button class="btn-camera-select full-width-btn" onclick="toggleLiveCameraFeed('https://trafficcams.vancouver.ca/granville70th.htm')">Granville and 70th Avenue</button>
            <button class="btn-camera-select full-width-btn" onclick="toggleLiveCameraFeed('https://trafficcams.vancouver.ca/granvillerobson.htm')">Granville and Robson</button>
            <button class="btn-camera-select full-width-btn" onclick="toggleLiveCameraFeed('https://trafficcams.vancouver.ca/hastings.htm')">Hastings and Boundary Rd.</button>
            <button class="btn-camera-select full-width-btn" onclick="toggleLiveCameraFeed('https://trafficcams.vancouver.ca/transcanada01.htm')">HWY 1 and 1st Ave</button>
            <button class="btn-camera-select full-width-btn" onclick="toggleLiveCameraFeed('https://trafficcams.vancouver.ca/knightMarineBridge.htm')">Knight Street Bridge</button>
            <button class="btn-camera-select full-width-btn" onclick="toggleLiveCameraFeed('https://trafficcams.vancouver.ca/oak4.htm')">Oak and 70th</button>
            <button class="btn-camera-select full-width-btn" onclick="toggleLiveCameraFeed('https://trafficcams.vancouver.ca/cameraimages/BeattyDunsmuirEast.jpg')">Viaduct Westbound</button>
            <button class="btn-camera-select full-width-btn" onclick="toggleLiveCameraFeed('https://trafficcams.vancouver.ca/denman3.htm')">W Georgia and Denman st.</button>
        </div>
        
        <div id="live-cam-display-box" class="cam-display-box">
            <img id="hud-cam-feed" class="cam-img-frame" src="" alt="Live Traffic Feed Loading..." onclick="launchFullscreenViewer()" />
            <div style="text-align:center; font-size:11px; margin-top:5px; font-weight:bold; color:#666;">SWIPE LEFT/RIGHT TO SWITCH • TAP FOR FULLSCREEN</div>
        </div>
        
        <button class="btn-close-cam" onclick="hideModals()">Close Menu</button>
    </div> 

    <div id="lightbox-viewer" class="fullscreen-lightbox">
        <button class="btn-close-lightbox" onclick="exitFullscreenViewer()">✕</button>
        <img id="lightbox-target-img" src="" alt="Full Screen Display" />
    </div> 

    <div id="flag-pop" class="driver-modal flag-grid">
        <span class="modal-title">Drop Flag Intersection</span>
        <div class="grid-options">
            <button class="btn-flag-cardinal" onclick="dropFlagDirect('Northbound')">North</button>
            <button class="btn-flag-cardinal" onclick="dropFlagDirect('Southbound')">South</button>
            <button class="btn-flag-cardinal" onclick="dropFlagDirect('Eastbound')">East</button>
            <button class="btn-flag-cardinal" onclick="dropFlagDirect('Westbound')">West</button>
            
            <button class="btn-flag-corner" onclick="dropFlagDirect('Northeast Corner')">Northeast</button>
            <button class="btn-flag-corner" onclick="dropFlagDirect('Northwest Corner')">Northwest</button>
            <button class="btn-flag-corner" onclick="dropFlagDirect('Southeast Corner')">Southeast</button>
            <button class="btn-flag-corner" onclick="dropFlagDirect('Southwest Corner')">Southwest</button>

            <button class="btn-flag-hotel full-width-btn" onclick="dropFlagDirect('Hotel Driveway')">🏨 HOTELS</button>
        </div>
    </div> 

    <div id="caution-type-pop" class="driver-modal caution-grid">
        <span class="modal-title">Caution Condition</span>
        <div class="grid-options">
            <button class="btn-caution-opt full-width-btn" onclick="selectCautionType('Mild traffic')">Mild Traffic</button>
            <button class="btn-caution-opt full-width-btn" onclick="selectCautionType('Heavy traffic')">Heavy Traffic</button>
