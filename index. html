    <div id="police-pop" class="driver-modal police-grid">
        <span class="modal-title">Police Threat Zone</span>
        <div class="grid-options">
            <button class="btn-police-opt full-width-btn" onclick="selectPoliceType('Radar')">Radar</button>
            <button class="btn-police-opt full-width-btn" onclick="selectPoliceType('Emergency')">Emergency</button>
            <button class="btn-police-opt full-width-btn" onclick="selectPoliceType('Hidden setup')">Hidden</button>
        </div>
    </div> 

    <div id="police-dir-pop" class="driver-modal police-grid">
        <span class="modal-title">Police Direction</span>
        <div class="grid-options">
            <button class="btn-police-opt" onclick="dropPoliceMarker('Northbound')">North</button>
            <button class="btn-police-opt" onclick="dropPoliceMarker('Southbound')">South</button>
            <button class="btn-police-opt" onclick="dropPoliceMarker('Eastbound')">East</button>
            <button class="btn-police-opt" onclick="dropPoliceMarker('Westbound')">West</button>
            <button class="btn-police-opt full-width-btn" onclick="dropPoliceMarker('All Directions')">All Directions</button>
        </div>
    </div> 

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        // Initialize Map Object - Locked strictly North-up
        const map = L.map('map', { 
            zoomControl: false, 
            maxZoom: 18,
            dragging: true,
            touchZoom: true,
            doubleClickZoom: true,
            scrollWheelZoom: true
        }).setView([49.2611, -123.1281], 16); 
        
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map); 

        // Core Status State Monitoring Parameters
        let vehiclePos = null;
        let lastGeocodedPos = null;
        let vehicleMarker = null;
        let trackVehicleView = true; 
        let audioMuted = false;
        let wakeLockToken = null;
        let cameraRefreshInterval = null;
        let activeCamUrl = ""; 
        let activeRawTargetUrl = ""; 

        // Selection Handlers
        let chosenCautionType = "";
        let chosenPoliceType = ""; 

        // Dynamic Live Cache resolving addresses cleanly
        let currentAddressData = { houseNumber: "", streetName: "Unknown Street", isLoaded: false }; 
        
        // Variable tracking storage for audio replay history
        let lastSpokenSpeechString = "";

        // Custom Top-Down Vector Yellow Taxi Marker
        const taxiIconStyle = L.divIcon({
            className: 'taxi-vector-icon',
            html: 'TAXI',
            iconSize: [26, 26],
            iconAnchor: [13, 13]
        }); 

        // Setup touch tracking variables for camera sliding functionality
        let touchStartX = 0;
        let touchEndX = 0;
        const minimumSwipeDistance = 50; 
        const cameraFeedImage = document.getElementById('hud-cam-feed');

        cameraFeedImage.addEventListener('touchstart', function(event) {
            touchStartX = event.changedTouches[0].screenX;
        }, { passive: true });

        cameraFeedImage.addEventListener('touchend', function(event) {
            touchEndX = event.changedTouches[0].screenX;
            evaluateSwipeDirection();
        }, { passive: true });


        // ==========================================
        // LANDMARK: CAMERA SWIPE INTERACTIVE MANAGER
        // What it does: Analyzes horizontal finger swipes across the live feed image to switch cams.
        // Where it's used: Triggered automatically by touch event handlers on the camera stream view box.
        // ==========================================
        function evaluateSwipeDirection() {
            const cameraButtons = Array.from(document.querySelectorAll('#camera-list-options button'));
            if (cameraButtons.length === 0) return;

            let currentIndex = cameraButtons.findIndex(btn => {
                return btn.getAttribute('onclick').includes(activeRawTargetUrl);
            });

            if (currentIndex === -1) return;

            if (touchStartX - touchEndX > minimumSwipeDistance) {
                let nextIndex = (currentIndex + 1) % cameraButtons.length;
                cameraButtons[nextIndex].click();
                cameraButtons[nextIndex].scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            } else if (touchEndX - touchStartX > minimumSwipeDistance) {
                let prevIndex = (currentIndex - 1 + cameraButtons.length) % cameraButtons.length;
                cameraButtons[prevIndex].click();
                cameraButtons[prevIndex].scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }
        }


        // ==========================================
        // LANDMARK: OPEN CAMERA SELECTION WINDOW
        // What it does: Resets active stream cache, cleans style highlight classes, and opens camera modal box.
        // Where it's used: Called immediately when the primary top-HUD "CAMERAS" action button is pressed.
        // ==========================================
        function openCameraListMenu() {
            document.getElementById('live-cam-display-box').style.display = 'none';
            activeCamUrl = "";
            activeRawTargetUrl = "";
            document.querySelectorAll('#camera-list-options button').forEach(btn => btn.classList.remove('selected-cam'));
            if (cameraRefreshInterval) clearInterval(cameraRefreshInterval);
            showModal('camera-menu-pop');
        } 


        // ==========================================
        // LANDMARK: DYNAMIC LIVE CAMERA STREAM PARSER
        // What it does: Maps static web endpoints to active live image links and instantly projects them full-screen.
        // Where it's used: Activated whenever an individual camera location row item is selected inside the modal list.
        // ==========================================
        function toggleLiveCameraFeed(targetUrl) {
            activeRawTargetUrl = targetUrl;

            document.querySelectorAll('#camera-list-options button').forEach(btn => {
                if (btn.getAttribute('onclick').includes(targetUrl)) {
                    btn.classList.add('selected-cam');
                } else {
                    btn.classList.remove('selected-cam');
                }
            });

            let dynamicImageUrl = targetUrl;
            if (targetUrl.endsWith('.htm') || targetUrl.endsWith('.html')) {
                const urlParts = targetUrl.split('/');
                const filename = urlParts[urlParts.length - 1].replace('.htm', '.jpg').replace('.html', '.jpg');
                let correctedFilename = filename;
                if (filename === 'transcanada01.jpg') correctedFilename = 'TransCanada01.jpg';
                else if (filename === 'hastings.jpg') correctedFilename = 'HastingsBoundaryEast.jpg';
                else if (filename === 'denman3.jpg') correctedFilename = 'GeorgiaDenmanWest.jpg';
                else if (filename === 'granvillerobson.jpg') correctedFilename = 'GranvilleRobsonNorth.jpg';
                else if (filename === 'cambiebridge.jpg') correctedFilename = 'CambieBridgeDeck.jpg';
                else if (filename === 'oak4.jpg') correctedFilename = 'Oak70thNorth.jpg';
                else if (filename === 'granvilleHoweOnRamp.jpg') correctedFilename = 'GranvilleHoweOnRamp.jpg';
                else if (filename === 'knightMarineBridge.jpg') correctedFilename = 'KnightMarineBridgeNorth.jpg';
                else if (filename === 'granville70th.jpg') correctedFilename = 'Granville70thNorth.jpg';
                
                dynamicImageUrl = `https://trafficcams.vancouver.ca/cameraimages/${correctedFilename}`;
            } 

            activeCamUrl = dynamicImageUrl;
            launchFullscreenViewer();
        } 


        // ==========================================
        // LANDMARK: FULL SCREEN LIGHTBOX PROJECTOR
        // What it does: Launches the custom black canvas overlay to show the current camera stream in full viewport size.
        // Where it's used: Executed automatically by the image parser, or when manually tapping a preview panel.
        // ==========================================
        function launchFullscreenViewer() {
            if (!activeCamUrl) return;
            const lightbox = document.getElementById('lightbox-viewer');
            const lightboxImg = document.getElementById('lightbox-target-img');
            
            lightboxImg.onclick = function() {
                exitFullscreenViewer();
            };
            
            lightboxImg.src = `${activeCamUrl}?t=${Date.now()}`;
            lightbox.style.display = 'flex';
        } 


        // ==========================================
        // LANDMARK: DISMISS FULL SCREEN LIGHTBOX
        // What it does: Shuts down the black full-screen image display canvas to restore background workspace view.
        // Where it's used: Activated by clicking the "✕" close layout circle button or tapping straight onto the image.
        // ==========================================
        function exitFullscreenViewer() {
            document.getElementById('lightbox-viewer').style.display = 'none';
        } 

        // GEOLOCATION ENGINE INITIALIZATION
        map.locate({ watch: true, enableHighAccuracy: true, timeout: 10000, maximumAge: 0 }); 

        map.on('locationfound', function(e) {
            vehiclePos = e.latlng;
            
            if (!vehicleMarker) {
                vehicleMarker = L.marker(e.latlng, { icon: taxiIconStyle }).addTo(map);
                map.setView(e.latlng, 17);
            } else {
                vehicleMarker.setLatLng(e.latlng);
            } 

            if (trackVehicleView) {
                map.setView(e.latlng, 17);
            } 

            fetchAddressFromCoordinates(e.latlng);
        }); 

        // PERSISTENT VIEWPORT RE-CENTER REDUNDANCY LOOP
        setInterval(() => {
            if (trackVehicleView && vehiclePos) {
                map.setView(vehiclePos, 17);
            }
        }, 2000);
        
        map.on('dragstart', function() {
            trackVehicleView = false;
            const btn = document.getElementById('lock-center-btn');
            btn.className = "util-circle";
            btn.innerHTML = "MAP<br>FREE";
        }); 


        // ==========================================
        // LANDMARK: REVERSE GEOLOCATION ENGINE
        // What it does: Converts latitude/longitude GPS numbers into real street names and house numbers via Nominatim OpenStreetMap.
        // Where it's used: Fired continuously by the movement tracker script whenever the driver shifts location.
        // FIXED: Removed the unsupported custom 'timeout' option configuration property that breaks standard fetch behaviors.
        // ==========================================
        function fetchAddressFromCoordinates(latlng, forcedCallback = null) {
            let distanceMoved = 0;
            if (lastGeocodedPos) {
                distanceMoved = latlng.distanceTo(lastGeocodedPos);
            } 

            if (lastGeocodedPos && distanceMoved < 15 && currentAddressData.isLoaded && !forcedCallback) {
                if (forcedCallback) forcedCallback();
                return;
            } 

            const url = `https://nominatim.openstreetmap.org/reverse?format=json&lat=${latlng.lat}&lon=${latlng.lng}&zoom=18&addressdetails=1&_cb=${Date.now()}`; 

            fetch(url, { headers: { 'Accept-Language': 'en' } })
                .then(res => res.json())
                .then(data => {
                    if (data && data.address) {
                        currentAddressData.streetName = data.address.road || data.address.pedestrian || data.address.suburb || "Street Route";
                        currentAddressData.houseNumber = data.address.house_number || "";
                        currentAddressData.isLoaded = true;
                        lastGeocodedPos = latlng;
                    }
                    if (forcedCallback) forcedCallback();
                })
                .catch(err => {
                    console.log("Geocoding recovery active: " + err.message);
                    if (distanceMoved > 20) {
                        currentAddressData.houseNumber = "";
                        currentAddressData.streetName = `Zone Track [${latlng.lat.toFixed(3)}]`;
                    }
                    if (forcedCallback) forcedCallback();
                });
        } 


        // ==========================================
        // LANDMARK: MODAL DISPLAY TRIGGER
        // What it does: Activates the main dim dark background blocker layer and renders the targeted menu container window visible.
        // Where it's used: Attached directly to the main layout control panel icons across the layout header.
        // ==========================================
        function showModal(id) {
            document.getElementById('screen-overlay').style.display = 'block';
            document.getElementById(id).style.display = 'block';
        } 


        // ==========================================
        // LANDMARK: GLOBAL MODAL CLOSURE SUBROUTINE
        // What it does: Sweeps the workspace screen clean by turning off every active driver menu modal and background mask layer.
        // Where it's used: Triggered when tapping outside an action box or clicking explicit close cancel interface buttons.
        // ==========================================
        function hideModals() {
            document.getElementById('screen-overlay').style.display = 'none';
            document.querySelectorAll('.driver-modal').forEach(m => m.style.display = 'none');
            if (cameraRefreshInterval) clearInterval(cameraRefreshInterval);
            activeCamUrl = "";
            activeRawTargetUrl = "";
        } 


        // ==========================================
        // LANDMARK: VEHICLE VIEW RE-CENTER TRACKER
        // What it does: Re-engages the automated camera locking frame to keep the yellow taxi indicator pinned dead-center on screen.
        // Where it's used: Triggered when pressing the right-side middle "MAP FREE" utility circular navigation option.
        // ==========================================
        function handleRecenter() {
            trackVehicleView = true;
            const btn = document.getElementById('lock-center-btn');
            btn.className = "util-circle active-center";
            btn.innerHTML = "MAP<br>LOCKED";
            if (vehiclePos) {
                map.setView(vehiclePos, 17);
            }
        } 


        // ==========================================
        // LANDMARK: AUDIO MUTE MANAGEMENT INTERFACE
        // What it does: Toggles the audio engine state variable and transforms button skin between grey and bright alarm red.
        // Where it's used: Activated by pressing the top-left corner side circular control button element.
        // ==========================================
        function handleMuteToggle() {
            audioMuted = !audioMuted;
            const btn = document.getElementById('mute-toggle-btn');
            if(audioMuted) {
                btn.className = "util-circle active-mute";
                btn.innerHTML = "AUDIO<br>MUTED";
            } else {
                btn.className = "util-circle";
                btn.innerHTML = "AUDIO<br>ON";
            }
        } 


        // ==========================================
        // LANDMARK: DISPATCH PASSENGER FLAG MARKER
        // What it does: Places a passenger icon at current location coordinates with an interactive cross-platform map routing hyperlink.
        // Where it's used: Called when choosing an orientation or hotel option within the primary flag popup terminal list.
        // SECURITY PATCH: Replaced blocked 'googleusercontent' mirror link framework with safe native web coordinate parameters.
        // ==========================================
        function dropFlagDirect(selectionValue) {
            hideModals(); 
            if (!vehiclePos) return; 

            const targetPos = vehiclePos; 

            fetchAddressFromCoordinates(targetPos, function() {
                const redManIcon = L.divIcon({
                    className: 'red-man-icon',
                    html: selectionValue === 'Hotel Driveway' ? '🏨' : '🚶',
                    iconSize: [34, 34],
                    iconAnchor: [17, 32]
                }); 

                const flagMarker = L.marker(targetPos, { icon: redManIcon }).addTo(map);
                const completeAddress = currentAddressData.houseNumber ? `${currentAddressData.houseNumber} ${currentAddressData.streetName}` : currentAddressData.streetName;
                
                // FIXED: Repaired broken template literal syntax block and secured deep link structure
                const navigationUrl = `https://www.google.com/maps/search/?api=1&query=${targetPos.lat},${targetPos.lng}`;

                let headerLabel = `<strong style="color:#ff3b30;">FLAG WAITING</strong>`;
                if (selectionValue === 'Hotel Driveway') {
                    headerLabel = `<strong style="color:#5856d6;">HOTEL DISPATCH FLAG</strong>`;
                }

                flagMarker.bindPopup(`
                    ${headerLabel}<br>
                    <strong>Placement:</strong> ${selectionValue}<br>
                    <span>Location: ${completeAddress}</span><br><br>
                    <a href="${navigationUrl}" target="_blank" style="display:block; text-align:center; background:#007aff; color:white; font-weight:bold; padding:8px 10px; border-radius:6px; text-decoration:none; margin-top:5px; text-transform:uppercase; font-size:11px;">Navigate to Flag</a>
                `).openPopup(); 

                dispatchAudioNarration('Flag', selectionValue); 

                // Automatic cleanup policy: drops tracking instance from canvas layers after exactly 5 minutes
                setTimeout(() => {
                    map.removeLayer(flagMarker);
                }, 300000); 
            });
        } 


        // ==========================================
        // LANDMARK: CAUTION STAGE 1 ROUTER
        // What it does: Registers the specific category of obstruction picked and advances display interface straight onto step 2 panel.
        // Where it's used: Attached directly to individual items inside the yellow "CAUTION" warning window panel list.
        // ==========================================
        function selectCautionType(type) {
            chosenCautionType = type;
            hideModals();
            showModal('caution-dir-pop');
        } 


        // ==========================================
        // LANDMARK: PROJECT CAUTION ANCHOR ON MAP
        // What it does: Draws a solid yellow circle marker alert onto current map view zone loaded with reverse address data blocks.
        // Where it's used: Fired immediately when selecting a target driving vector option from the Caution direction matrix panel.
        // ==========================================
        function dropCautionMarker(directionValue) {
            hideModals(); 
            if (!vehiclePos) return; 

            const targetPos = vehiclePos;
            const typeLabel = chosenCautionType;
            const directionLabel = directionValue; 

            fetchAddressFromCoordinates(targetPos, function() {
                const dynamicMarker = L.circleMarker(targetPos, {
                    color: '#b38f00',
                    fillColor: '#ffcc00',
                    fillOpacity: 1.0, 
                    weight: 3,
                    radius: 14
                }).addTo(map); 

                const completeAddress = currentAddressData.houseNumber ? `${currentAddressData.houseNumber} ${currentAddressData.streetName}` : currentAddressData.streetName; 

                dynamicMarker.bindPopup(`
                    <strong style="color:#b38f00;">${typeLabel.toUpperCase()}</strong><br>
                    <strong>Direction:</strong> ${directionLabel}<br>
                    <span>Location: ${completeAddress}</span>
                `).openPopup(); 

                dispatchAudioNarration('Caution', { type: typeLabel, direction: directionLabel });
            });
        } 


        // ==========================================
        // LANDMARK: POLICE STAGE 1 ROUTER
        // What it does: Logs whether enforcement threat tracking profile matches Radar, Emergency or Hidden setups and shuffles view into step 2.
        // Where it's used: Linked directly to clicking elements inside the primary "POLICE" enforcement intercept menu panel.
        // ==========================================
        function selectPoliceType(type) {
            chosenPoliceType = type;
            hideModals();
            showModal('police-dir-pop');
        } 


        // ==========================================
        // LANDMARK: PROJECT POLICE ENFORCEMENT ZONE
        // What it does: Pins a solid blue warning indicator point marker block onto map layout containing current geocoded data matrices.
        // Where it's used: Triggered immediately when selecting a structural direction option inside the final police setup view window.
        // ==========================================
        function dropPoliceMarker(directionValue) {
            hideModals(); 
            if (!vehiclePos) return; 

            const targetPos = vehiclePos;
            const typeLabel = chosenPoliceType;
            const directionLabel = directionValue; 

            fetchAddressFromCoordinates(targetPos, function() {
                const dynamicMarker = L.circleMarker(targetPos, {
                    color: '#0044cc',
                    fillColor: '#007aff',
                    fillOpacity: 1.0, 
                    weight: 3,
                    radius: 14
                }).addTo(map); 

                const completeAddress = currentAddressData.houseNumber ? `${currentAddressData.houseNumber} ${currentAddressData.streetName}` : currentAddressData.streetName; 

                dynamicMarker.bindPopup(`
                    <strong style="color:#007aff;">POLICE REPORTED</strong><br>
                    <strong>Type:</strong> ${typeLabel} (${directionLabel})<br>
                    <span>Location: ${completeAddress}</span>
                `).openPopup(); 

                dispatchAudioNarration('Police', { type: typeLabel, direction: directionLabel });
            });
        } 


        // ==========================================
        // LANDMARK: AUDIO ADDRESS COUPLES STRING CONVERTER
        // What it does: Breaks standard 3 and 4-digit street block integers down into vocal pair groupings (e.g. 1441 to "14 41").
        // Where it's used: Internal optimization subroutine run continuously right before triggering native TTS output arrays.
        // ==========================================
        function breakHouseNumbersIntoCouples(numberStr) {
            if (!numberStr || isNaN(numberStr)) return numberStr;
            
            if (numberStr.length === 4) {
                const leadingPair = parseInt(numberStr.substring(0, 2), 10);
                const trailingPair = parseInt(numberStr.substring(2, 4), 10);
                if (trailingPair === 0) return `${leadingPair} hundred`;
                if (trailingPair < 10) return `${leadingPair} oh ${trailingPair}`;
                return `${leadingPair} ${trailingPair}`;
            }
            
            if (numberStr.length === 3) {
                const leadingDigit = parseInt(numberStr.substring(0, 1), 10);
                const trailingPair = parseInt(numberStr.substring(1, 3), 10);
                if (trailingPair === 0) return `${leadingDigit} hundred`;
                if (trailingPair < 10) return `${leadingDigit} oh ${trailingPair}`;
                return `${leadingDigit} ${trailingPair}`;
            } 

            return numberStr;
        } 


        // ==========================================
        // LANDMARK: CENTRAL TEXT-TO-SPEECH BROADCAST MACHINE
        // What it does: Assembles plain English alert strings and flushes audio buffers with an isolated delay to prevent clipping over Bluetooth.
        // Where it's used: Automatically invoked whenever a flag, caution obstacle, or police vehicle trap is successfully saved onto the map field.
        // ==========================================
        function dispatchAudioNarration(category, payload) {
            const spokenHouseNumber = breakHouseNumbersIntoCouples(currentAddressData.houseNumber);
            const addressAudioString = spokenHouseNumber ? `${spokenHouseNumber} ${currentAddressData.streetName}` : currentAddressData.streetName;
            
            let finalSpeechString = "";
            
            if (category === 'Flag') {
                if (payload === 'Hotel Driveway') {
                    finalSpeechString = `One flag waiting inside the driveway of the hotel at ${addressAudioString}`;
                } else {
                    finalSpeechString = `One flag waiting ${payload.toLowerCase()} at ${addressAudioString}`;
                }
            } 
            else if (category === 'Caution') {
                finalSpeechString = `One ${payload.type.toLowerCase()} reported ahead ${payload.direction.toLowerCase()} at ${addressAudioString}`;
            } 
            else if (category === 'Police') {
                finalSpeechString = `One police reported ahead ${payload.direction.toLowerCase()} at ${addressAudioString} radar radar`;
            } 

            lastSpokenSpeechString = finalSpeechString;

            if (audioMuted) return; 

            const clearHardwareBuffer = new SpeechSynthesisUtterance("");
            window.speechSynthesis.speak(clearHardwareBuffer); 

            setTimeout(() => {
                const utterance = new SpeechSynthesisUtterance(finalSpeechString);
                utterance.rate = 1.0; 
                window.speechSynthesis.speak(utterance);
            }, 1500);
        } 


        // ==========================================
        // LANDMARK: INSTANT AUDIO CACHE REPLAY SUBROUTINE
        // What it does: Reads the active voice broadcast string straight out of memory logs and plays it back with near-zero latency latency.
        // Where it's used: Attached directly to the middle left side "REPLAY MSG" purple dashboard icon utility action button component.
        // ==========================================
        function replayLastAudioNarration() {
            if (!lastSpokenSpeechString) return;
            
            const clearHardwareBuffer = new SpeechSynthesisUtterance("");
            window.speechSynthesis.speak(clearHardwareBuffer); 

            setTimeout(() => {
                const utterance = new SpeechSynthesisUtterance(lastSpokenSpeechString);
                utterance.rate = 1.0; 
                window.speechSynthesis.speak(utterance);
            }, 200);
        }


        // ==========================================
        // LANDMARK: HARDWARE DISPLAY ANTI-BLACKOUT ENGINE
        // What it does: Requests a navigator screen lock profile to stop mobile device screen timers from putting displays to sleep while on shift.
        // Where it's used: Activated instantly during page initialization cycles, and monitors background visibility changes.
        // ==========================================
        async function maintainScreenWakeLock() {
            try {
                if ('wakeLock' in navigator) {
                    wakeLockToken = await navigator.wakeLock.request('screen');
                }
            } catch (err) {
                console.log("Wake lock framework notice: " + err.message);
            }
        } 

        window.addEventListener('load', maintainScreenWakeLock); 

        document.addEventListener('visibilitychange', async () => {
            if (wakeLockToken !== null && document.visibilityState === 'visible') {
                maintainScreenWakeLock();
            }
        });
    </script>
</body>
